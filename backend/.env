# This part is the root configuration for the NASS (Naflows Authentication Service System)
# DO NOT EDIT THIS FILE UNLESS YOU KNOW WHAT YOU ARE DOING
# DO NOT EDIT PARAMETERS STARTING WITH THE PREFIX "NASS_"
# For editing policies, please refer to the NASS documentation or contact the NASS support team


# Security tunnels
# Enable UCR (User-Client Request) settings
NASS_UCR_ENABLED=true
NASS_RATES_LIMIT_ENABLED=true
# Enable SCV (Secure Connection Verification) settings 
NASS_SCV_ENABLED=true
NASS_SERVICE_FILTER=true
# Enable SSV (Secure Session Verification) settings
NASS_SSV_ENABLED=true 
# Enable STV (Secure Token Verification) settings
NASS_STV_ENABLED=true 
# Enable STC (Secure Tokenization for Client) settings
NASS_STC_ENABLED=true
# Enable IP Blacklist settings
NASS_BLACKLIST_ENABLED=true



# SCV (Secure Connection Verification) settings
# Minimum expiration time for service tokens in seconds
SERVICE_TOKEN_MIN_EXPIRATION=3600 
# Maximum expiration time for service tokens in seconds
SERVICE_TOKEN_MAX_EXPIRATION=43200
# Maximum number of connections before forcing a new token 
SERVICE_TOKEN_MAXIMAL_RATES=1000
# Minimum time before a backlisted ip gets removed from the blacklist in seconds
BLACKLIST_MINIMAL_TIMEOUT=300
# Maximum number of connections per minute before an IP is blacklisted
BLACKLIST_RATES=30
# Time in seconds before the blacklist rate is reset
BLACKLIST_RATES_TIMEOUT=60


# SSV (Secure Session Verification) settings
# Minimum session timeout in seconds
SESSION_MINIMAL_TIMEOUT=300  
# Session renewal time in seconds
SESSION_RENEWAL_LIFESPAN=1728000
# Token duration in seconds
SESSION_TOKEN_DURATION=1728000
# Default Session Renewal's token uses
SESSION_RENEWAL_TOKEN_DEFAULT_USES=1


# STV (Secure Token Verification) settings
# Minimum time a token is frozen for
STV_MINIMAL_TIMEOUT_MIN=1 # TEST PURPOSES ONLY : 1
# Maximum time a token is frozen for
STV_MINIMAL_TIMEOUT_MAX=5 # TEST PURPOSES ONLY : 5
# Maximum number of uses for a token before it is renewed
STV_MAXIMAL_USE_RATES=100



# STC (Secure Tokenization for Client) settings
# Minimum time a token is valid for in seconds
STC_MINIMAL_TIMEOUT=3600
# Maximum time a token is valid for in seconds
STC_MAXIMAL_TIMEOUT=43200
# Contract lifespan 
CONTRACT_LIFESPAN=60