# This file is the root configuration for the NASS (Naflows Authentication Service System)
# DO NOT EDIT THIS FILE UNLESS YOU KNOW WHAT YOU ARE DOING
# DO NOT EDIT PARAMETERS STARTING WITH THE PREFIX "NASS_"
# For editing policies, please refer to the NASS documentation or contact the NASS support team


# Security tunnels
NASS_UCR_ENABLED=true # Enable UCR (User Connection Rate) settings
NASS_SCV_ENABLED=true # Enable SCV (Secure Connection Verification) settings
NASS_SSV_ENABLED=true # Enable SSV (Secure Session Verification) settings
NASS_STV_ENABLED=true # Enable STV (Secure Token Verification) settings
NASS_STC_ENABLED=true # Enable STC (Secure Tokenization for Client) settings
NASS_BLACKLIST_ENABLED=true # Enable IP Blacklist settings



# SCV (Secure Connection Verification) settings

SERVICE_TOKEN_MIN_EXPIRATION=3600 # Minimum expiration time for service tokens in seconds
SERVICE_TOKEN_MAX_EXPIRATION=43200 # Maximum expiration time for service tokens in seconds
SERVICE_TOKEN_MAXIMAL_RATES=1000 # Maximum number of connections before forcing a new token 

BLACKLIST_MINIMAL_TIMEOUT=300 # Minimum time before a backlisted ip gets removed from the blacklist in seconds
BLACKLIST_RATES=30 # Maximum number of connections per minute before an IP is blacklisted
BLACKLIST_RATES_TIMEOUT=60 # Time in seconds before the blacklist rate is reset


# STV (Secure Token Verification) settings
STV_MINIMAL_TIMEOUT_MIN=1 # Minimum time a token is frozen for
STV_MINIMAL_TIMEOUT_MAX=5 # Maximum time a token is frozen for
STV_MAXIMAL_USE_RATES=100 # Maximum number of uses for a token before it is renewed

# STC (Secure Tokenization for Client) settings
STC_MINIMAL_TIMEOUT=3600 # Minimum time a token is valid for in seconds
STC_MAXIMAL_TIMEOUT=43200 # Maximum time a token is valid for in seconds